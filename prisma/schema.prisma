// LIPS - Ligue des Imams et Prédicateurs du Sénégal
// Système d'Information Institutionnel National (SIIN)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// --- DOMAINE GOUVERNANCE & INSTITUTIONNEL ---

model Region {
  id            Int      @id @default(autoincrement())
  code          String   @unique // DKR, SLG, LGN, etc.
  nom           String
  nomAr         String?
  population    Int?
  mosqueCount   Int?
  latitude      Float?
  longitude     Float?
  responsableId Int?
  mosques       Mosque[]
  members       User[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// --- DOMAINE MEMBRES ---

model User {
  id        Int       @id @default(autoincrement())
  matricule String    @unique // Ex: LIPS-2025-DKR-000124
  email     String    @unique
  password  String
  nom       String
  prenom    String
  telephone String
  photo     String?
  roleId    Int?
  role      Role?     @relation(fields: [roleId], references: [id])
  status    String    @default("EN_ATTENTE") // ACTIF, EXPIRE, EN_ATTENTE

  regionId  Int?
  region    Region?   @relation(fields: [regionId], references: [id])

  mosqueId  Int?
  mosque    Mosque?   @relation(fields: [mosqueId], references: [id])
  commissions Commission[] @relation("UserCommissions")

  carteMembre   CarteMembre?
  paiements     Paiement[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Mosque {
  id       Int    @id @default(autoincrement())
  nom      String
  adresse  String
  regionId Int
  region   Region @relation(fields: [regionId], references: [id])
  imams    User[]
}

// --- DOMAINE RBAC (Role-Based Access Control) ---

model Role {
  id          Int          @id @default(autoincrement())
  name        String       @unique // Ex: SUPER_ADMIN, ADMIN_REGIONAL, IMAM
  description String?
  permissions Permission[] @relation("RolePermissions")
  users       User[]
}

model Permission {
  id          Int     @id @default(autoincrement())
  action      String  @unique // Ex: manage:users, manage:finances, publish:fatwa
  description String?
  roles       Role[]  @relation("RolePermissions")
}

// --- DOMAINE CARTE MEMBRE & VÉRIFICATION ---

model CarteMembre {
  id            Int      @id @default(autoincrement())
  numeroCarte   String   @unique // Identique au matricule user
  qrCodeUrl     String
  dateEmission  DateTime @default(now())
  dateExpiration DateTime
  userId        Int      @unique
  user          User     @relation(fields: [userId], references: [id])
}

// --- DOMAINE FINANCIER ---

model Paiement {
  id             Int      @id @default(autoincrement())
  montant        Float
  type           String   // COTISATION, DON, ADHESION
  referenceTrans String   @unique
  methode        String   // CinetPay, Wave, Espèces
  datePaiement   DateTime @default(now())
  userId         Int
  user           User     @relation(fields: [userId], references: [id])
}

// --- DOMAINE COMMUNICATION & FORMATION ---

model Content {
  id          Int      @id @default(autoincrement())
  titre       String
  titreAr     String?
  contenu     String
  contenuAr   String?
  type        String   // COMMUNIQUE, ARTICLE, FATWA, COURS, SEMINAIRE, EVENEMENT
  categorie   String?  // fiqh, aqida, daawa, société
  fichierUrl  String?  // PDF, Audio, Vidéo
  imageUrl    String?  // Image de couverture
  published   Boolean  @default(false)
  dateEvenement DateTime? // Pour les événements
  lieu        String?    // Pour les événements
  auteurId    Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// --- DOMAINE PARAMÈTRES & CONFIGURATION ---

model SiteConfig {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}

// --- DOMAINE FAQ ---

model FAQ {
  id        Int      @id @default(autoincrement())
  question  String
  reponse   String
  ordre     Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- DOMAINE MEMBRES BUREAU ---

model BureauMember {
  id        Int      @id @default(autoincrement())
  nom       String
  prenom    String
  role      String
  roleAr    String?
  region    String?
  bio       String?
  initiales String?
  ordre     Int      @default(0)
  photo     String?
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- DOMAINE COMMISSIONS ---

model Commission {
  id        Int      @id @default(autoincrement())
  nom       String
  nomAr     String?
  members   Int      @default(0)
  desc      String?
  icon      String? // lucide icon name
  ordre        Int      @default(0)
  published    Boolean  @default(true)
  membersList  User[]   @relation("UserCommissions")
}

// --- DOMAINE CONCOURS ---

model Concours {
  id                    Int      @id @default(autoincrement())
  nom                   String
  type                  String   // CONCOURS_CORAN, CONCOURS_HADITH, CONCOURS_MEMORISATION, QUIZ_ISLAMIQUE
  dateDebut             DateTime
  dateFin               DateTime?
  lieu                  String?
  description           String?
  descriptionAr         String?
  participantsEst       Int?
  visiblePublic         Boolean  @default(false)
  inscriptionsOuvertes  Boolean  @default(false)
  statut                String   @default("PLANIFIE") // PLANIFIE, EN_COURS, TERMINE
  imageUrl              String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// --- DOMAINE CORAN ---

model CoranReciter {
  id        Int      @id @default(autoincrement())
  name      String
  bio       String?
  published Boolean  @default(false)
  ordre     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DailyVerse {
  id         Int      @id @default(autoincrement())
  arabic     String
  french     String
  reference  String
  published  Boolean  @default(false)
  dateActive DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model CoranResource {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  url         String?
  icon        String   @default("BookOpen")
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// --- DOMAINE AGENDA ---

model Event {
  id          Int      @id @default(autoincrement())
  titre       String
  titreAr     String?
  description String?
  descriptionAr String?
  dateDebut   DateTime
  dateFin     DateTime?
  lieu        String?
  type        String   @default("LIPS") // LIPS, ISLAMIQUE, FORMATION, COMMUNAUTE
  categorie   String?  // conference, formation, celebration, etc.
  published   Boolean  @default(false)
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// --- DOMAINE CMS STATIC PAGES & UI TEXTS ---

model StaticPage {
  id          Int      @id @default(autoincrement())
  slug        String   @unique // ex: 'accueil', 'a-propos'
  title       String
  titleAr     String?
  content     String?  // Peut stocker du JSON structuré ou du Markdown/HTML
  contentAr   String?
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model UIText {
  id          Int      @id @default(autoincrement())
  key         String   @unique // ex: 'btn.adherer', 'home.hero.title'
  value       String
  valueAr     String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// --- DOMAINE GALERIE ---

model Galerie {
  id        Int      @id @default(autoincrement())
  titre     String
  titreAr   String?
  lieu      String?
  date      String?
  count     Int      @default(0)
  gradient  String?  @default("from-lips-green-dark to-lips-green")
  imageUrl  String?
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- DOMAINE STATISTIQUES ---

model Statistique {
  id        Int      @id @default(autoincrement())
  key       String   @unique // ex: 'mosquees', 'membres'
  icon      String?  // lucide icon name
  value     Int
  suffix    String?
  label     String
  labelAr   String?
  desc      String?
  descAr    String?
  ordre     Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
