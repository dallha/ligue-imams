p text-center\">لماذا تختار <br class=\"d-none d-sm-block\">منصتنا الاليكترونية\n            </h2>-->\n            <div class=\"row row-sm row-30\">\n\n                <div class=\"col-md-6 col-lg-3 wow fadeInUp\">\n                    <article class=\"service-corporate unit flex-column flex-sm-row\">\n                        <div class=\"unit-body\">\n                            <div class=\"unit-body-warp\">\n                                <div class=\"service-corporate-image\">\n                                    <img src=\"/assets/themes/azhar/assets/img/usp-zero.png\">\n                                </div>\n\n                                <h4 class=\"service-corporate-title\">محتوى تعليمي رقمي </h4>\n                                <p class=\"service-corporate-text\">إدارة كافة أنواع المحتويات التعليمية الرقمية بشكل مركزي مع إتاحة اثراء المحتوى التعليمي من خلال المعلمين</p>\n                            </div>\n\n                        </div>\n                    </article>\n                </div>\n\n                <div class=\"col-md-6 col-lg-3 wow fadeInUp\">\n                    <article class=\"service-corporate unit flex-column flex-sm-row\">\n                        <div class=\"unit-body\">\n                            <div class=\"unit-body-warp\">\n                                <div class=\"service-corporate-image\">\n                                    <img src=\"/assets/themes/azhar/assets/img/usp-two.png\">\n                                </div>\n\n                                <h4 class=\"service-corporate-title\">أسئلة وتدريبات</h4>\n                                <p class=\"service-corporate-text\">أسئلة وتدريبات وواجبات واختبارات مع تقييم مستمر للطالب</p>\n                            </div>\n\n                        </div>\n                    </article>\n                </div>\n\n                <div class=\"col-md-6 col-lg-3 wow fadeInUp\">\n                    <article class=\"service-corporate unit flex-column flex-sm-row\">\n                        <div class=\"unit-body\">\n                            <div class=\"unit-body-warp\">\n                                <div class=\"service-corporate-image\">\n                                    <img src=\"/assets/themes/azhar/assets/img/usp-one.png\">\n                                </div>\n\n                                <h4 class=\"service-corporate-title\">مؤشرات واحصائيات</h4>\n                                <p class=\"service-corporate-text\">توفير مؤشرات واحصائيات مع اتاحة متابعة العملية التعليمية </p>\n                            </div>\n\n                        </div>\n                    </article>\n                </div>\n\n                <div class=\"col-md-6 col-lg-3 wow fadeInUp\">\n                    <article class=\"service-corporate unit flex-column flex-sm-row\">\n                        <div class=\"unit-body\">\n                            <div class=\"unit-body-warp\">\n                                <div class=\"service-corporate-image\">\n                                    <img src=\"/assets/themes/azhar/assets/img/usp-three.png\">\n                                </div>\n\n                                <h4 class=\"service-corporate-title\">تواصل فعال</h4>\n                                <p class=\"service-corporate-text\">تواصل فعال بين المعلم والطالب وولي الامر والإدارة التعليمية</p>\n                            </div>\n\n                        </div>\n                    </article>\n                </div>\n            </div>\n        </div>\n    </section>\n    <section class=\"section section-inset-2 bg-default\">\n        <div class=\"container\">\n            <div class=\"row row-30\">\n                <div class=\"col-md-6 col-xl-5 wow fadeInUp\" data-wow-delay=\".05s\">\n                    <h2>أسلوب للتفوق بطريقة آمنة توفر وقت وجهد الطلاب</h2>\n                    <p class=\"big offset-top-3\">تقدم المنصة التعليمية المناهج الدراسية عبر الإنترنت بشكل متكامل ومبسط، وبطريقة توفر وقت وجهد الطلاب وتضمن سلامتهم في مختلف الظروف.</p>\n                    <!--<a class=\"button button-secondary button-nuka offset-top-2\" href=\"#\">Learn More<span class=\"button-overlay\"></span></a>-->\n                </div>\n\n                <div class=\"col-md-6 col-xl-7 text-right wow fadeInUp\">\n                    <img src=\"/assets/themes/azhar/assets/img/blur-seo-1-660x406.png\" alt=\"\" width=\"660\" height=\"406\">\n                </div>\n            </div>\n        </div>\n    </section>\n    <!--<section class=\"section section-inset-2 section-inset-6 bg-default text-center\">\n      <div class=\"container\">\n        <h2 class=\"wow fadeInUp\">Over 5,000 companies trust us with their <br class=\"d-none d-md-block\">success on the internet\n        </h2>\n        <div class=\"row row-30 align-items-center justify-content-around wow fadeInUp\">\n          <div class=\"col-auto\"><a class=\"client-classic\" href=\"#\"><img src=\"images/landing-corporate-34-50x71.png\" alt=\"\" width=\"50\" height=\"71\"/></a></div>\n          <div class=\"col-auto\"><a class=\"client-classic\" href=\"#\"><img src=\"images/landing-corporate-35-68x67.png\" alt=\"\" width=\"68\" height=\"67\"/></a></div>\n          <div class=\"col-auto\"><a class=\"client-classic\" href=\"#\"><img src=\"images/landing-corporate-36-94x71.png\" alt=\"\" width=\"94\" height=\"71\"/></a></div>\n          <div class=\"col-auto\"><a class=\"client-classic\" href=\"#\"><img src=\"images/landing-corporate-37-38x84.png\" alt=\"\" width=\"38\" height=\"84\"/></a></div>\n          <div class=\"col-auto\"><a class=\"client-classic\" href=\"#\"><img src=\"images/landing-corporate-38-103x57.png\" alt=\"\" width=\"103\" height=\"57\"/></a></div>\n        </div>\n      </div>\n    </section>-->\n</div>\n\n<section class=\"section section-inset-7 bg-gradient-primary-1\">\n    <div class=\"container\">\n        <div class=\"row\">\n            <div class=\"col-md-10 wow fadeIn\">\n                <h2>منصة منارة الأزهر التعلي